# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Email (for notifications, use Gmail app password or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@leosauctions.com
FROM_NAME=Leo's Auctions

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Image uploads — choose one option:
# OPTION A: Cloudinary (recommended, free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
USE_CLOUDINARY=true

# OPTION B: Local storage fallback (no config needed)
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./backend/uploads

# Contact Form — where to receive contact form submissions
CONTACT_TO_EMAIL=leo@leosauctions.com    # Your business email (where form emails go)
